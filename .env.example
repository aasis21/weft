# Helm — environment template. Copy to .env (extension) / .env.local (mobile) and fill in.
# NEVER commit real values. Secrets are provided via environment only.

# Extension relay (Node process). Names are Helm-namespaced on purpose: a generic
# SUPABASE_URL / SUPABASE_ANON_KEY exported globally for another project would hijack the
# relay. Set HELM_TRANSPORT=supabase to use the relay; otherwise LocalTransport (dev/test).
HELM_TRANSPORT=supabase
HELM_SUPABASE_URL=
HELM_SUPABASE_ANON_KEY=

# Mobile build (Vite reads VITE_-prefixed vars)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: approval timeout (ms) before the missing-phone safety net denies. Default 120000.
HELM_APPROVAL_TIMEOUT_MS=120000
