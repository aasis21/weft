# Helm — environment template. Copy to .env (extension) / .env.local (mobile) and fill in.
# NEVER commit real values. Secrets are provided via environment only.

# Supabase project (create a fresh project; wire its MCP like kirana360).
# Phase 2 (relay) consumes these. Until then, LocalTransport is used for dev/test.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Mobile build (Vite reads VITE_-prefixed vars)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: approval timeout (ms) before the missing-phone safety net denies. Default 120000.
HELM_APPROVAL_TIMEOUT_MS=120000
