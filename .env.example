# Weft — environment template for the MOBILE WEB BUILD ONLY (mobile/.env.local).
# NEVER commit real values.
#
# The Copilot CLI extension's transport (Supabase vs. devtunnel) is NOT env/.env-based at all:
# it is configured once via `weft set-transport supabase --url <url> --anon-key <key>` (or
# `weft set-transport devtunnel`), persisted to ~/.weft/weft.config.json, and read from nowhere
# else. This keeps reinstalling/rebuilding the extension from ever silently overriding your
# chosen transport.

# Mobile build (Vite reads VITE_-prefixed vars)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional, advanced: approval timeout (ms) before the missing-phone safety net denies the tool
# call. Default 120000. Set as a real environment variable before `copilot` if you want to change
# it — this is a runtime tuning knob, not part of the transport config.
WEFT_APPROVAL_TIMEOUT_MS=120000
